root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = tab
indent_style = tab
insert_final_newline = true
max_line_length = off
tab_width = 4
trim_trailing_whitespace = true

[*.css]
ij_css_brace_placement = end_of_line
ij_css_space_after_colon = true
ij_css_space_before_opening_brace = true
ij_css_use_double_quotes = true
ij_css_value_alignment = do_not_align


[{*.html,*.htm}]
ij_html_add_new_line_before_tags = html,head,body,div,p,form,h1,h2,h3
ij_html_attribute_wrap = off
ij_html_enforce_quotes = true
ij_html_quote_style = double
ij_html_text_wrap = off

[{*.js,*.cjs,*.mjs}]
ij_javascript_enforce_trailing_comma = whenmultiline
ij_javascript_force_quote_style = false
ij_javascript_force_semicolon_style = true
ij_javascript_import_sort_members = true
ij_javascript_import_sort_module_name = true
ij_javascript_import_use_node_resolution = false
ij_javascript_spaces_within_array_initializer_brackets = true
ij_javascript_spaces_within_brackets = true
ij_javascript_spaces_within_imports = true
ij_javascript_use_double_quotes = true
ij_javascript_use_semicolon_after_statement = true

[{*.ts,*.tsx,*.mts}]
ij_typescript_enforce_trailing_comma = whenmultiline
ij_typescript_force_quote_style = false
ij_typescript_spaces_within_array_initializer_brackets = true
ij_typescript_spaces_within_brackets = true
ij_typescript_use_double_quotes = true
ij_typescript_use_import_type = always

[{*.yml,*.yaml}]
indent_size = 4
indent_style = space
